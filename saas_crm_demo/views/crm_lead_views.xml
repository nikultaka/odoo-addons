<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    ============================================================
    CRM Lead Form View Extension
    ============================================================
    This adds our custom fields (Company Code, Tenant Name) to
    the existing CRM Lead form. We use "xpath" to find the exact
    position where we want to insert our fields.
    ============================================================
    -->

    <record id="view_crm_lead_form_saas_demo" model="ir.ui.view">
        <field name="name">crm.lead.form.saas.demo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Add our fields AFTER the "expected_revenue" field -->
            <xpath expr="//field[@name='expected_revenue']" position="after">
                <!-- Separator to make our fields stand out -->
                <separator string="SaaS Tenant Info" />
                <group>
                    <field name="company_code" placeholder="e.g., ACME-001" widget="char"/>
                    <field name="tenant_name" placeholder="e.g., Acme Corporation"/>
                </group>
            </xpath>

        </field>
    </record>

    <!--
    ============================================================
    CRM Lead Tree (List) View Extension
    ============================================================
    This adds the "Company Code" column to the list view of leads,
    so you can see it without opening each lead.
    ============================================================
    -->

    <record id="view_crm_lead_tree_saas_demo" model="ir.ui.view">
        <field name="name">crm.lead.tree.saas.demo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">

            <!-- Add Company Code column after the contact name -->
            <xpath expr="//field[@name='contact_name']" position="after">
                <field name="company_code" optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>
